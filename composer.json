{
    "name": "inpost/magento2-module-restrictions",
    "description": "Module allows for configuration of restrictions for products not handled by InPost Pay.",
    "type": "magento2-module",
    "license": ["CC-BY-NC-ND-4.0"],
    "require": {
        "php": ">=8.1",
        "magento/framework": "*",
        "monolog/monolog": "*",
        "psr/log": "*",
        "magento/module-ui": "*",
        "magento/module-catalog-rule": "*"
    },
    "autoload": {
        "files": [
            "src/registration.php"
        ],
        "psr-4": {
            "InPost\\Restrictions\\": "src"
        }
    },
    "keywords": [
        "magento2",
        "inpostpay"
    ]
}

